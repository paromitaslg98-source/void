<?xml version="1.0" encoding="utf-8"?>
<!-- MD3 Expressive outlined card — pure AMOLED black fill, crisp white 20% stroke -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <!-- 20dp corners: Material You standard for expressive cards -->
    <corners android:radius="20dp" />
    <!-- True black for AMOLED — saves battery, maximises contrast -->
    <solid android:color="#FF000000" />
    <!-- Subtle 16% white stroke — visible but not glaring on AMOLED -->
    <stroke
        android:width="1dp"
        android:color="#29FFFFFF" />
</shape>
