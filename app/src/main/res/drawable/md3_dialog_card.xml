<?xml version="1.0" encoding="utf-8"?>
<!-- MD3 dialog card — elevated surface with deeper charcoal fill for contrast vs screen -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <corners android:radius="20dp" />
    <!-- Slightly elevated from pure black: #0D0D0D gives 96% dark but not blending into bg -->
    <solid android:color="#FF0D0D0D" />
    <stroke
        android:width="1dp"
        android:color="#33FFFFFF" />
</shape>
