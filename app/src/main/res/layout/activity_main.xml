<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainActivityLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:animateLayoutChanges="true">

    <fragment
        android:id="@+id/nav_host_fragment"
        android:name="androidx.navigation.fragment.NavHostFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:defaultNavHost="true"
        app:navGraph="@navigation/nav_graph"
        tools:ignore="FragmentTagUsage" />

    <!-- Dialog overlay — theme-adaptive, fully readable in both light & dark -->
    <FrameLayout
        android:id="@+id/messageLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?attr/dialogShadeColor"
        android:clickable="true"
        android:clipToPadding="false"
        android:focusable="true"
        android:padding="28dp"
        android:visibility="gone"
        tools:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/md3_dialog_card"
            android:elevation="8dp"
            android:orientation="vertical"
            android:padding="24dp"
            tools:targetApi="p">

            <!-- Title row with close button -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp">

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:layout_marginEnd="44dp"
                    android:clickable="false"
                    android:fontFamily="@font/google_sans_medium"
                    android:includeFontPadding="false"
                    android:letterSpacing="-0.01"
                    android:text="@string/app_name"
                    android:textColor="?attr/primaryColor"
                    android:textSize="20sp" />

                <ImageView
                    android:id="@+id/ivClose"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="end|center_vertical"
                    android:alpha="0.6"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/close"
                    android:padding="6dp"
                    android:src="@drawable/ic_close"
                    android:tint="?attr/primaryColor" />
            </FrameLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/md3_divider" />

            <!-- Message body -->
            <TextView
                android:id="@+id/tvMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/google_sans_regular"
                android:lineSpacingExtra="3dp"
                android:textColor="?attr/primaryColor"
                android:textSize="15sp"
                tools:text="@string/welcome_to_void_settings" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/md3_divider" />

            <!-- Action button — right-aligned -->
            <TextView
                android:id="@+id/tvAction"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="4dp"
                android:background="?attr/selectableItemBackground"
                android:fontFamily="@font/google_sans_medium"
                android:letterSpacing="0.06"
                android:padding="8dp"
                android:text="@string/okay"
                android:textAllCaps="true"
                android:textColor="?attr/primaryColor"
                android:textSize="13sp" />

        </LinearLayout>
    </FrameLayout>
</FrameLayout>