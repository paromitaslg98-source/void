                android:textColor="#EEEEEE"
                android:textColorHint="#B3EEEEEE"
                android:textSize="18sp"
                android:visibility="gone"
                tools:visibility="visible" />

        </LinearLayout>

    </LinearLayout>

    <!-- First-run tip — centered bottom -->
    <TextView
        android:id="@+id/firstRunTips"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="80dp"
        android:fontFamily="sans-serif"
        android:letterSpacing="0.02"
        android:text="@string/swipe_up_for_apps"
        android:textColor="?attr/primaryColorTrans80"
        android:textSize="13sp"
        android:visibility="gone"
        tools:visibility="visible" />

    <!-- Set-default CTA — bottom-center, outlined -->
    <TextView
        android:id="@+id/setDefaultLauncher"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="64dp"
        android:background="@drawable/md3_outlined_card"
        android:ellipsize="end"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.03"
        android:maxLines="1"
        android:paddingHorizontal="28dp"
        android:paddingVertical="16dp"
        android:text="@string/set_as_default_launcher_u"
        android:textColor="?attr/primaryColor"
        android:textSize="15sp"
        android:visibility="gone" />

</FrameLayout>