<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:animateLayoutChanges="true"
    tools:context=".ui.HomeFragment">

    <!-- Lock screen placeholder -->
    <FrameLayout
        android:id="@+id/lock"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:contentDescription="@string/lock_layout_description" />

    <!-- Screen time moved inside dateTimeLayout -->

    <!-- Clock + Date — top-left, with generous top clearance for status bar -->
    <LinearLayout
        android:id="@+id/dateTimeLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="72dp"
        android:orientation="vertical"
        android:paddingHorizontal="28dp"
        android:visibility="gone"
        tools:visibility="visible">

        <!-- Time — thin display, very large, always 24h HH:MM -->
        <TextClock
            android:id="@+id/clock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-thin"
            android:format24Hour="HH:mm"
            android:includeFontPadding="false"
            android:letterSpacing="-0.04"
            android:textColor="?attr/primaryColor"
            android:textSize="88sp"
            tools:text="09:41" />

        <!-- Date — Roboto regular, uppercase, well spaced -->
        <TextView
            android:id="@+id/date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="sans-serif"
            android:letterSpacing="0.08"
            android:textAllCaps="true"
            android:textColor="?attr/primaryColorTrans80"
            android:textSize="13sp"
            tools:text="WED, 25 FEB" />

        <!-- Screen time + Unlocks -->
        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvScreenTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="sans-serif"
            android:letterSpacing="0.03"
            android:textColor="?attr/primaryColorTrans80"
            android:textSize="13sp"
            android:visibility="gone"
            tools:text="2h 11m • 15 unlocks"
            tools:visibility="visible" />

    </LinearLayout>

    <!-- Home apps — bottom aligned inside a single filled card -->
    <LinearLayout
        android:id="@+id/homeAppsLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="bottom"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="140dp"
        android:paddingBottom="80dp">

        <!-- Single combined card wrapping all apps -->
        <LinearLayout
            android:id="@+id/homeAppsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/home_app_card"
            android:orientation="vertical"
            android:paddingVertical="4dp"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:id="@+id/homeApp1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:hint="@string/app"
                android:includeFontPadding="false"
                android:letterSpacing="0.005"
                android:paddingHorizontal="20dp"
                android:paddingVertical="14dp"
                android:tag="@string/tag_1"
                android:textColor="#EEEEEE"
                android:textColorHint="#B3EEEEEE"
                android:textSize="18sp"
                android:visibility="gone"
                tools:visibility="visible" />

            <View
                android:id="@+id/divider1"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginHorizontal="20dp"
                android:background="#4DEEEEEE"
                android:visibility="gone" />

            <TextView
