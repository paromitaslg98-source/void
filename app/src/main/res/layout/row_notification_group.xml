<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="16dp"
    android:background="@drawable/md3_filled_card"
    android:orientation="vertical"
    android:paddingHorizontal="16dp"
    android:paddingVertical="12dp">

    <!-- Header: icon + app name + count badge + time + expand arrow -->
    <LinearLayout
        android:id="@+id/llGroupHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/ivAppIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="@null" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvAppName"
                style="@style/TextMedium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                tools:text="Messages" />

            <TextView
                android:id="@+id/tvCount"
                style="@style/TextSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/md3_badge"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:textColor="?attr/colorSurface"
                android:textSize="11sp"
                android:textStyle="bold"
                android:visibility="gone"
                tools:text="3" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvTime"
            style="@style/TextSmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:alpha="0.7"
            android:textSize="12sp"
            android:layout_marginEnd="4dp"
            tools:text="12m" />

        <ImageView
            android:id="@+id/ivExpand"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:contentDescription="Expand"
            android:src="@drawable/ic_expand_more"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Latest notification preview (shown when collapsed) -->
    <LinearLayout
        android:id="@+id/llLatestPreview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingVertical="8dp"
        android:background="?attr/selectableItemBackground">

        <TextView
            android:id="@+id/tvTitle"
            style="@style/TextDefault"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="32dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textStyle="bold"
            tools:text="John Doe" />

        <TextView
            android:id="@+id/tvText"
            style="@style/TextDefault"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="32dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:alpha="0.8"
            tools:text="Hey, are we still on for later?" />

    </LinearLayout>

    <!-- Expanded children container (hidden by default) -->
    <LinearLayout
        android:id="@+id/llChildren"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone" />

</LinearLayout>
