<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainActivityLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:animateLayoutChanges="true"
    android:background="?attr/colorSurface">

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:animateLayoutChanges="true"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:fadingEdgeLength="48dp"
        android:overScrollMode="never"
        android:requiresFadingEdge="vertical"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/scrollLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:orientation="vertical"
            android:paddingTop="72dp"
            android:paddingBottom="56dp"
            android:paddingHorizontal="20dp">

            <!-- =====================================================
                 SECTION: App Header
            ===================================================== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/md3_outlined_card"
                android:orientation="vertical"
                android:padding="20dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <!-- "VOID Launcher" also acts as hidden-apps trigger (long press) -->
                    <TextView
                        android:id="@+id/olauncherHiddenApps"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="-0.01"
                        android:text="@string/app_name"
                        android:textColor="?attr/primaryColor"
                        android:textSize="22sp" />

                    <ImageView
                        android:id="@+id/appInfo"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="end|center_vertical"
                        android:contentDescription="@string/info"
                        android:padding="4dp"
                        android:src="@drawable/ic_info"
                        android:tint="?attr/primaryColorTrans80" />
                </FrameLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginVertical="14dp" android:background="@drawable/md3_divider" />

                <TextView
                    android:id="@+id/setLauncher"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif"
                    android:paddingVertical="10dp"
                    android:text="@string/set_as_default_launcher"
                    android:textColor="?attr/primaryColor"
                    android:textSize="15sp" />

                <!-- Hidden stubs — code references them but we don't show them -->
                <TextView android:id="@+id/aboutOlauncher" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                <TextView android:id="@+id/moreFeatures" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="14dp" />

            <!-- =====================================================
                 SECTION: Home Screen
            ===================================================== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/md3_outlined_card"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.10"
                    android:text="@string/home_screen"
                    android:textAllCaps="true"
                    android:textColor="?attr/primaryColorTrans80"
                    android:textSize="10sp" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginTop="12dp" android:layout_marginBottom="4dp" android:background="@drawable/md3_divider" />

                <!-- # Apps on Home -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:animateLayoutChanges="true"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:orientation="vertical">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif"
                            android:paddingVertical="14dp"
                            android:text="@string/apps_on_home_screen"
                            android:textColor="?attr/primaryColor"
                            android:textSize="15sp" />
                        <TextView
                            android:id="@+id/homeAppsNum"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="end|center_vertical"
                            android:fontFamily="sans-serif-medium"
                            android:paddingVertical="14dp"
                            android:textColor="?attr/primaryColor"
                            android:textSize="15sp"
                            tools:text="4" />
                    </FrameLayout>

                        <!-- Moved appsNumSelectLayout to popupOverlay -->
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@drawable/md3_divider" />

                <!-- Show date/time -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:animateLayoutChanges="true"
                    android:orientation="vertical">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="sans-serif" android:paddingVertical="14dp" android:text="@string/show_date_time" android:textColor="?attr/primaryColor" android:textSize="15sp" />
                        <TextView android:id="@+id/dateTime" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="end|center_vertical" android:fontFamily="sans-serif-medium" android:paddingVertical="14dp" android:text="@string/on" android:textColor="?attr/primaryColor" android:textSize="15sp" />
                    </FrameLayout>

                    <!-- Moved dateTimeSelectLayout to popupOverlay -->
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@drawable/md3_divider" />

                <!-- App Alignment -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:animateLayoutChanges="true"
                    android:clipChildren="false"
                    android:orientation="vertical">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="sans-serif" android:paddingVertical="14dp" android:text="@string/home_layout_alignment" android:textColor="?attr/primaryColor" android:textSize="15sp" />
                        <TextView android:id="@+id/alignment" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="end|center_vertical" android:fontFamily="sans-serif-medium" android:paddingVertical="14dp" android:text="@string/left" android:textColor="?attr/primaryColor" android:textSize="15sp" />
                    </FrameLayout>

                    <!-- Moved alignmentSelectLayout to popupOverlay -->
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@drawable/md3_divider" />

                <!-- Screen Time -->
                <FrameLayout
                    android:id="@+id/screenTimeLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="sans-serif" android:paddingVertical="14dp" android:text="@string/screen_time" android:textColor="?attr/primaryColor" android:textSize="15sp" />
                    <TextView android:id="@+id/screenTimeOnOff" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="end|center_vertical" android:fontFamily="sans-serif-medium" android:paddingVertical="14dp" android:text="@string/off" android:textColor="?attr/primaryColor" android:textSize="15sp" />
                </FrameLayout>

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="14dp" />

            <!-- =====================================================
                 SECTION: Appearance
            ===================================================== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/md3_outlined_card"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.10"
                    android:text="@string/appearance"
                    android:textAllCaps="true"
                    android:textColor="?attr/primaryColorTrans80"
                    android:textSize="10sp" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginTop="12dp" android:layout_marginBottom="4dp" android:background="@drawable/md3_divider" />

                <!-- Auto-keyboard -->
                <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="sans-serif" android:paddingVertical="14dp" android:text="@string/auto_show_keyboard" android:textColor="?attr/primaryColor" android:textSize="15sp" />
                    <TextView android:id="@+id/autoShowKeyboard" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="end|center_vertical" android:fontFamily="sans-serif-medium" android:paddingVertical="14dp" android:text="@string/on" android:textColor="?attr/primaryColor" android:textSize="15sp" />
                </FrameLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@drawable/md3_divider" />

                <!-- Notification bar -->
                <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="sans-serif" android:paddingVertical="14dp" android:text="@string/notification_bar" android:textColor="?attr/primaryColor" android:textSize="15sp" />
                    <TextView android:id="@+id/statusBar" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="end|center_vertical" android:fontFamily="sans-serif-medium" android:paddingVertical="14dp" android:text="@string/off" android:textColor="?attr/primaryColor" android:textSize="15sp" />
                </FrameLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@drawable/md3_divider" />

                <!-- Text size — KEY FIX: selector appears BELOW the row, not overlapping it -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:animateLayoutChanges="true"
                    android:clipChildren="false"
                    android:orientation="vertical">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="sans-serif" android:paddingVertical="14dp" android:text="@string/text_size" android:textColor="?attr/primaryColor" android:textSize="15sp" />
                        <TextView android:id="@+id/textSizeValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="end|center_vertical" android:fontFamily="sans-serif-medium" android:paddingVertical="14dp" android:textColor="?attr/primaryColor" android:textSize="15sp" tools:text="1.0" />
                    </FrameLayout>

                    <!-- Moved textSizesLayout to popupOverlay -->
                </LinearLayout>

                <!-- Hidden stubs for wallpaper/theme (kept for Kotlin compat) -->
                <TextView android:id="@+id/dailyWallpaperUrl" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                <TextView android:id="@+id/dailyWallpaper" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                <TextView android:id="@+id/appThemeText" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                <LinearLayout android:id="@+id/appThemeSelectLayout" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone">
                    <TextView android:id="@+id/themeSystem" android:layout_width="0dp" android:layout_height="0dp" />
                    <TextView android:id="@+id/themeLight" android:layout_width="0dp" android:layout_height="0dp" />
                    <TextView android:id="@+id/themeDark" android:layout_width="0dp" android:layout_height="0dp" />
                </LinearLayout>

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="14dp" />

            <!-- =====================================================
                 SECTION: Gestures
            ===================================================== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:animateLayoutChanges="true"
                android:background="@drawable/md3_outlined_card"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tvGestures"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.10"
                    android:text="@string/gestures"
                    android:textAllCaps="true"
                    android:textColor="?attr/primaryColorTrans80"
                    android:textSize="10sp" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginTop="12dp" android:layout_marginBottom="4dp" android:background="@drawable/md3_divider" />

                <!-- Swipe Left -->
                <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="sans-serif" android:paddingVertical="14dp" android:text="@string/swipe_left_app" android:textColor="?attr/primaryColor" android:textSize="15sp" />
                    <TextView android:id="@+id/swipeLeftApp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="end|center_vertical" android:fontFamily="sans-serif-medium" android:maxLines="1" android:paddingVertical="14dp" android:textColor="?attr/primaryColor" android:textSize="15sp" />
                </FrameLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@drawable/md3_divider" />

                <!-- Swipe Right -->
                <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="sans-serif" android:paddingVertical="14dp" android:text="@string/swipe_right_app" android:textColor="?attr/primaryColor" android:textSize="15sp" />
                    <TextView android:id="@+id/swipeRightApp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="end|center_vertical" android:fontFamily="sans-serif-medium" android:maxLines="1" android:paddingVertical="14dp" android:textColor="?attr/primaryColor" android:textSize="15sp" />
                </FrameLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@drawable/md3_divider" />

                <!-- Swipe Down -->
                <LinearLayout
                    android:id="@+id/flSwipeDown"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:animateLayoutChanges="true"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="sans-serif" android:paddingVertical="14dp" android:text="@string/swipe_down_for" android:textColor="?attr/primaryColor" android:textSize="15sp" />
                        <TextView android:id="@+id/swipeDownAction" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="end|center_vertical" android:fontFamily="sans-serif-medium" android:maxLines="1" android:paddingVertical="14dp" android:textColor="?attr/primaryColor" android:textSize="15sp" tools:text="@string/search" />
                    </FrameLayout>

                    <!-- Moved swipeDownSelectLayout to popupOverlay -->

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@drawable/md3_divider" />
                </LinearLayout>

                <!-- Double-tap lock -->
                <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="sans-serif" android:paddingVertical="14dp" android:text="@string/double_tap_to_lock_screen" android:textColor="?attr/primaryColor" android:textSize="15sp" />
                    <TextView android:id="@+id/toggleLock" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="end|center_vertical" android:fontFamily="sans-serif-medium" android:paddingVertical="14dp" android:text="@string/off" android:textColor="?attr/primaryColor" android:textSize="15sp" />
                </FrameLayout>

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="24dp" />

            <!-- =====================================================
                 FOOTER — Credit line only, no redirecting links
            ===================================================== -->
            <TextView
                android:id="@+id/footer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif"
                android:gravity="center"
                android:letterSpacing="0.04"
                android:padding="12dp"
                android:text="Made by Surajit Das"
                android:textColor="?attr/primaryColorTrans80"
                android:textSize="13sp" />

            <!-- Hidden stubs for Kotlin click-handler references -->
            <LinearLayout android:layout_width="0dp" android:layout_height="0dp" android:orientation="horizontal">
                <TextView android:id="@+id/twitter" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                <TextView android:id="@+id/share" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                <TextView android:id="@+id/rate" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                <TextView android:id="@+id/github" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                <TextView android:id="@+id/privacy" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- =====================================================
         Accessibility dialog overlay
    ===================================================== -->
    <FrameLayout
        android:id="@+id/accessibilityLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?attr/dialogShadeColor"
        android:clickable="true"
        android:clipToPadding="false"
        android:focusable="true"
        android:padding="28dp"
        android:visibility="gone"
        tools:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/md3_dialog_card"
            android:elevation="8dp"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="-0.01"
                android:text="@string/double_tap_lock"
                android:textColor="?attr/primaryColor"
                android:textSize="20sp" />

            <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginVertical="16dp" android:background="@drawable/md3_divider" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif"
                android:lineSpacingExtra="3dp"
                android:text="@string/accessibility_disclosure"
                android:textColor="?attr/primaryColor"
                android:textSize="14sp" />

            <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginVertical="16dp" android:background="@drawable/md3_divider" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/notWorking"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif"
                    android:paddingVertical="8dp"
                    android:text="@string/not_working"
                    android:textColor="?attr/primaryColorTrans80"
                    android:textSize="13sp"
                    android:visibility="gone"
                    tools:visibility="visible" />

                <TextView
                    android:id="@+id/closeAccessibility"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.06"
                    android:paddingVertical="8dp"
                    android:paddingHorizontal="16dp"
                    android:text="@string/close"
                    android:textAllCaps="true"
                    android:textColor="?attr/primaryColor"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/actionAccessibility"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/md3_outlined_card"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.06"
                    android:paddingVertical="8dp"
                    android:paddingHorizontal="16dp"
                    android:text="@string/enable"
                    android:textAllCaps="true"
                    android:textColor="?attr/primaryColor"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

    <!-- =====================================================
         Pop-up overlay for settings controls
    ===================================================== -->
    <FrameLayout
        android:id="@+id/popupOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?attr/dialogShadeColor"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <!-- Container for dynamically centered select layouts -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:paddingHorizontal="24dp">

            <LinearLayout
                android:id="@+id/appsNumSelectLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:animateLayoutChanges="true"
                android:background="@drawable/popup_card"
                android:orientation="horizontal"
                android:visibility="gone">

                <TextView android:id="@+id/maxApps0" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:fontFamily="sans-serif-medium" android:gravity="center" android:paddingVertical="12dp" android:text="@string/_0" android:textColor="?attr/primaryColor" android:textSize="14sp" />
                <View android:layout_width="1dp" android:layout_height="18dp" android:layout_gravity="center_vertical" android:background="@drawable/md3_divider" />
                <TextView android:id="@+id/maxApps1" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:fontFamily="sans-serif-medium" android:gravity="center" android:paddingVertical="12dp" android:text="@string/_1" android:textColor="?attr/primaryColor" android:textSize="14sp" />
                <View android:layout_width="1dp" android:layout_height="18dp" android:layout_gravity="center_vertical" android:background="@drawable/md3_divider" />
                <TextView android:id="@+id/maxApps2" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:fontFamily="sans-serif-medium" android:gravity="center" android:paddingVertical="12dp" android:text="@string/_2" android:textColor="?attr/primaryColor" android:textSize="14sp" />
                <View android:layout_width="1dp" android:layout_height="18dp" android:layout_gravity="center_vertical" android:background="@drawable/md3_divider" />
                <TextView android:id="@+id/maxApps3" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:fontFamily="sans-serif-medium" android:gravity="center" android:paddingVertical="12dp" android:text="@string/_3" android:textColor="?attr/primaryColor" android:textSize="14sp" />
                <View android:layout_width="1dp" android:layout_height="18dp" android:layout_gravity="center_vertical" android:background="@drawable/md3_divider" />
                <TextView android:id="@+id/maxApps4" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:fontFamily="sans-serif-medium" android:gravity="center" android:paddingVertical="12dp" android:text="@string/_4" android:textColor="?attr/primaryColor" android:textSize="14sp" />
                <View android:layout_width="1dp" android:layout_height="18dp" android:layout_gravity="center_vertical" android:background="@drawable/md3_divider" />
                <TextView android:id="@+id/maxApps5" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:fontFamily="sans-serif-medium" android:gravity="center" android:paddingVertical="12dp" android:text="@string/_5" android:textColor="?attr/primaryColor" android:textSize="14sp" />
                <View android:layout_width="1dp" android:layout_height="18dp" android:layout_gravity="center_vertical" android:background="@drawable/md3_divider" />
                <TextView android:id="@+id/maxApps6" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:fontFamily="sans-serif-medium" android:gravity="center" android:paddingVertical="12dp" android:text="@string/_6" android:textColor="?attr/primaryColor" android:textSize="14sp" />
                <View android:layout_width="1dp" android:layout_height="18dp" android:layout_gravity="center_vertical" android:background="@drawable/md3_divider" />
