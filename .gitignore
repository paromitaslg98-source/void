# ── VOID Launcher Consolidation Gitignore ────────────────────────
# This file is optimized for the monolithic (root-level) structure.

# Gradle
.gradle/
build/
.gradletasknamecache

# Android Studio / IntelliJ
.idea/
*.iml
*.iws
*.ipr
out/
captures/
.externalNativeBuild/
.cxx/
local.properties

# Android Specific
*.apk
*.aab
output.json

# Signing / Keystore
*.jks
*.keystore
signing.properties
release-keystore.properties

# Kotlin
.kotlin/
kapt/
ksp/

# OS Generated
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# CI/CD & Fastlane
fastlane/report.xml
fastlane/Preview.html
fastlane/test_output

# Miscellaneous
*.log
*.hprof
*.swp
*~

# IDE run configurations
.idea/runConfigurations/

# Top-level scratch files and archives
/*.kt
/*.zip
/*.tar.gz
/*.rar

# ── Always Track ──
!.gitignore
!LICENSE
!README.md
!src/
!gradle/
!build.gradle*
!settings.gradle*
!proguard-rules.pro
!gradle.properties
